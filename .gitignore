cat > .gitignore << 'EOF'
# ============================================
# .GITIGNORE - Files to exclude from version control
# ============================================

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

# Sensitive files
*.pem
*.key
*.pem.backup
**/.env
**/.env.local
**/.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Node modules
node_modules/
package-lock.json

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backup files
*.bak
*.backup
*.old
*.orig
*.sql
*.sql.gz

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Application specific
backend/__pycache__/
backend/*.pyc
backend/.env
backend/.env.local
terraform/linkhub-key.pem
terraform/terraform.tfstate*
terraform/.terraform/

# Database
*.db
*.sqlite
*.sqlite3

# Secrets
secrets.tf
*.secret
*.secrets
EOF